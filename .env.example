# GEMINI_API_KEY: Required for Gemini AI API calls.
# Configure this with your Google AI Studio API key.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted (e.g. http://localhost:3000)
APP_URL="http://localhost:3000"

# SUPABASE_URL: The API URL for your Supabase project (from Project Settings > API)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# SUPABASE_ANON_KEY: The public anon key for your Supabase project (from Project Settings > API)
VITE_SUPABASE_ANON_KEY="your-anon-key"

